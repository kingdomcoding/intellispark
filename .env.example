APP_TARGET=dev
MIX_ENV=dev

# Default: connect to a Postgres running on the host at localhost:5432.
# The docker-compose.yml uses network_mode: host so the app container
# shares the host's network stack and reaches this Postgres directly.
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intellispark_dev
DATABASE_URL=ecto://postgres:postgres@localhost/intellispark_dev

SECRET_KEY_BASE=REPLACE_WITH_mix_phx.gen.secret
TOKEN_SIGNING_SECRET=REPLACE_WITH_mix_phx.gen.secret_64
PHX_HOST=localhost
# Used for generating absolute URLs (email links, redirects). Override to your
# public hostname (e.g. intellispark.example.com) + https + 443 when fronted by
# a reverse proxy. Defaults to http://localhost:4800 for bare dev.
PHX_URL_SCHEME=http
PHX_URL_PORT=4800
PHX_SERVER=true
PORT=4800
POOL_SIZE=10

RESEND_API_KEY=
